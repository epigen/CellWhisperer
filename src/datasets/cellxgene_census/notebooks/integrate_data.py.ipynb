   "id": "48611c1e-ca34-4d0b-a162-580b88ed57d2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def layerize_dataset(proc):\n",
    "    \"Generate `num_replicates` adata layers, each one containing one of the sampled cells. If a given group has less than `num_replicates` cells, repeatedly draw the existing cells (via modulo)\"\n",
    "    proc.obs[\"cell_id\"] = proc.obs.index.map(lambda v: v.rsplit(\"_\", maxsplit=2)[0])\n",
    "    adata = proc[proc.obs[\"is_pseudobulk\"] == \"True\"].copy()\n",
    "    for i in range(snakemake.params.num_replicates):\n",
    "        def get_replicate_modulo(cell_id):\n",
    "            candidates = proc.obs.index[(proc.obs[\"is_pseudobulk\"] == \"False\") & (proc.obs.cell_id == cell_id)]\n",
    "            return candidates[i % len(candidates)]\n",
    "        indices = adata.obs.cell_id.apply(get_replicate_modulo)\n",
    "        \n",
    "        adata.layers[f\"sampled_cell_{i}\"] = proc[indices].X\n",
    "\n",
    "    adata.obs.drop(columns=[\"is_pseudobulk\", \"replicate\"], inplace=True)\n",
    "    adata.obs[\"abstract\"] = adata.uns[\"abstract\"]\n",
    "    adata.obs[\"dataset_title\"] = adata.uns[\"dataset_title\"]\n",
    "    adata.uns = {}\n",
    "    return adata\n",
    "\n",
    "# layerize_dataset(proc)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "abee84ba-42e3-4dfc-b336-8e2cb4d623d7",
   "metadata": {
    "scrolled": true
   },
   "outputs": [],
   "source": [
    "# takes ~15 minutes\n",
    "\n",
    "datasets = []\n",
    "for fn in snakemake.input.datasets:\n",
    "    proc = anndata.read_h5ad(fn)\n",
    "    datasets.append(layerize_dataset(proc))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5e0f1f58-a272-4c1d-a3e2-1a33e079b473",
   "metadata": {},
   "outputs": [],
   "source": [
    "full = anndata.concat(datasets, join=\"outer\")\n",
    "del datasets, proc  # save memory"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9e9c1649-e9c2-41ce-99e9-4fc018ad7135",
   "metadata": {},
   "outputs": [],
   "source": [
    "# outer fills '0' in sparse matrices, so we will need to compress them\n",
    "for matrix in full.layers.values():\n",
    "    matrix.eliminate_zeros()\n",
    "    matrix = matrix.astype(np.int32)  # the join resulted in np.float64\n",
    "full.X.eliminate_zeros()\n",
    "full.X = full.X.astype(np.int32)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b9072de5-e174-444f-929d-7d28a910d00c",
   "metadata": {},
   "outputs": [],
   "source": [
    "full.obs[\"ensembl_id\"] = full.obs.index\n",
    "full.obs.drop(columns=[\"cluster_id\", \"GSE\"], inplace=True)  # fails otherwise\n",
    "ensembl_symbol_conversion = pd.read_csv(snakemake.input.ensembl_symbol_conversion).set_index(\"ensembl_gene_id\")[\"external_gene_name\"]\n",
    "full.var[\"gene_name\"] = full.var.index.map(ensembl_symbol_conversion.get)",
   ]
  },
