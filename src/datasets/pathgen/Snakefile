import subprocess
import os
from pathlib import Path

PROJECT_DIR = Path(subprocess.check_output("git rev-parse --show-toplevel", shell=True).decode("utf-8").strip())
configfile: PROJECT_DIR / "config.yaml"

include: "../../shared/config.smk"
include: "../../shared/rules/dataset_processing.smk"

# Configuration for testing mode
TESTING = os.environ.get("TESTING", "0") == "1"

rule download_pathgen_metadata:
    """
    Download PathGen-1.6M metadata JSON from HuggingFace.
    
    The JSON contains WSI IDs, patch positions, captions, and GDC file IDs.
    """
    output:
        metadata_json=PROJECT_DIR / "resources" / "pathgen" / "pathgen_1.6m.json"
    params:
        huggingface_url="https://huggingface.co/datasets/jamessyx/PathGen/resolve/main/PathGen-1.6M.json"
    conda:
        "envs/pathgen.yaml"
    resources:
        mem_mb=8000,
        slurm="cpus-per-task=2 time=02:00:00"
    script: "scripts/download_pathgen_metadata.py"

checkpoint extract_file_ids:
    """
    Extract unique GDC file IDs from the PathGen metadata JSON.
    
    In testing mode, only extract file IDs for the first 2 unique WSIs.
    """
    input:
        metadata_json=rules.download_pathgen_metadata.output.metadata_json,
        broken_ids="broken_datasets"
    output:
        file_ids_list=PROJECT_DIR / "results" / "pathgen" / "gdc_file_ids.txt",
        metadata_summary=PROJECT_DIR / "results" / "pathgen" / "metadata_summary.txt"
    params:
        testing_mode=TESTING
    conda: "envs/pathgen.yaml"
    script: "scripts/extract_file_ids.py"

rule download_gdc_file:
    """
    Download individual WSI files from GDC using the gdc-client tool.

    """
    output:
        wsi_file=protected(PROJECT_DIR / "scratch" / "pathgen" / "wsi_files" / "{file_id}.svs")
    resources:
        mem_mb=8000,
        slurm="cpus-per-task=2 time=04:00:00"
    shell: """
        curl -o {output.wsi_file} https://api.gdc.cancer.gov/data/{wildcards.file_id}
    """

def get_file_ids(wildcards):
    """
    Get list of file IDs to download based on checkpoint output.
    """
    checkpoint_output = checkpoints.extract_file_ids.get(**wildcards).output[0]
    with open(checkpoint_output) as f:
        file_ids = [line.strip() for line in f if line.strip()]
    
    # Return paths for all file IDs (even if empty list)
    return expand(PROJECT_DIR / "scratch" / "pathgen" / "wsi_files" / "{file_id}.svs", 
                  file_id=file_ids)

def get_wsi_file_ids(wildcards):
    """
    Get list of WSI file IDs (not full paths) for use in expand() patterns.
    """
    checkpoint_output = checkpoints.extract_file_ids.get(**wildcards).output[0]
    with open(checkpoint_output) as f:
        file_ids = [line.strip() for line in f if line.strip()]
    return file_ids

def get_wsi_metadata_outputs(wildcards):
    """
    Get list of individual metadata JSON files for each available WSI.
    """
    file_ids = get_wsi_file_ids(wildcards)
    return expand(PROJECT_DIR / "results" / "pathgen" / "metadata_per_wsi" / "{file_id}.json",
                  file_id=file_ids)

rule download_all_gdc_files:
    """
    Aggregate rule to ensure all required GDC files are downloaded.
    """
    input: get_file_ids
    output: 
        complete_marker=touch(PROJECT_DIR / "results" / "pathgen" / ".gdc_downloads_complete")
    shell: """
        echo "All GDC files downloaded successfully"
        echo "Downloaded $(ls -1 {PROJECT_DIR}/scratch/pathgen/wsi_files/*.svs 2>/dev/null | wc -l) WSI files"
    """

checkpoint filter_pathgen_metadata:
    """
    Filter PathGen metadata and create individual JSON files per WSI.
    
    This creates individual metadata files for each WSI, dramatically improving efficiency
    for downstream processing. Uses the filtered file IDs from extract_file_ids to ensure
    broken datasets are properly excluded. Also maintains backward compatibility.
    """
    input:
        metadata_json=rules.download_pathgen_metadata.output.metadata_json,
        file_ids_list=rules.extract_file_ids.output.file_ids_list,
        download_complete=rules.download_all_gdc_files.output.complete_marker
    output:
        metadata_per_wsi_dir=directory(PROJECT_DIR / "results" / "pathgen" / "metadata_per_wsi"),
        metadata_summary=PROJECT_DIR / "results" / "pathgen" / "metadata_filtering_summary.txt",
        metadata_filtered=PROJECT_DIR / "results" / "pathgen" / "pathgen_filtered.json"  # Legacy compatibility
    params:
        wsi_dir=PROJECT_DIR / "scratch" / "pathgen" / "wsi_files",
        testing_mode=TESTING,
        max_patches_per_wsi=float("inf") if not TESTING else 10
    conda: "envs/pathgen.yaml"
    script: "scripts/filter_metadata_per_wsi.py"

rule extract_svs_metadata:
    """
    Extract metadata from downloaded SVS files for diagnostic purposes.
    
    This rule extracts technical specifications including magnification, pixel size,
    image dimensions, and scanner information from all downloaded SVS files.
    The metadata is saved in both JSON and human-readable formats.
    """
    input:
        wsi_files=get_file_ids
    output:
        metadata_json=PROJECT_DIR / "results" / "pathgen" / "svs_metadata.json",
        metadata_txt=report(PROJECT_DIR / "results" / "pathgen" / "svs_metadata_report.txt", 
                           category="SVS Diagnostics", 
                           caption="Technical specifications of downloaded TCGA SVS files")
    conda: "envs/pathgen.yaml"
    resources:
        mem_mb=16000,
        slurm="cpus-per-task=2 time=02:00:00"
    script: "scripts/extract_svs_metadata.py"

rule create_wsi_h5ad:
    """
    Create h5ad file for a single WSI from PathGen data.
    
    This rule processes one WSI at a time, creating an h5ad file with patches as observations.
    Uses individual WSI metadata files for maximum efficiency.
    Image paths are stored in uns["image_path"] and captions in obs["natural_language_annotation"].
    Coordinates are center-oriented (x_pixel, y_pixel = patch centers).

    TODO: this writes static `0.5` pixel_size into `uns`. Might be better to use th metadata extracted from the SVS files.
    """
    input:
        wsi_metadata=PROJECT_DIR / "results" / "pathgen" / "metadata_per_wsi" / "{file_id}.json",
        wsi_file=PROJECT_DIR / "scratch" / "pathgen" / "wsi_files" / "{file_id}.svs"
    output:
        h5ad=PROJECT_DIR / "results" / "pathgen" / "h5ads" / "full_data_{file_id}.h5ad"
    params:
        patch_size=224  # Use 224x224 patches at 40x magnification (0.5 μm/pixel)
    conda: "envs/pathgen.yaml"
    resources:
        mem_mb=32000,
        slurm="cpus-per-task=2 time=04:00:00"
    script: "scripts/create_single_h5ad.py"

def get_all_h5ad_outputs(wildcards):
    """
    Get list of all h5ad files that should be created based on filtered file IDs.
    
    This ensures we only process WSI files that are:
    1. Not in the broken_datasets list (filtered by extract_file_ids)
    2. Successfully downloaded (available in wsi_files directory)
    3. Have metadata files created by filter_pathgen_metadata
    """
    # Get available metadata files from the checkpoint
    checkpoint_output = checkpoints.filter_pathgen_metadata.get(**wildcards).output.metadata_per_wsi_dir
    metadata_dir = Path(checkpoint_output)
    
    if metadata_dir.exists():
        # Only include files that have metadata files (which means they passed all filtering)
        file_ids = [f.stem for f in metadata_dir.glob("*.json")]
    else:
        file_ids = []
    
    return expand(PROJECT_DIR / "results" / "pathgen" / "h5ads" / "full_data_{file_id}.h5ad", 
                  file_id=file_ids)

rule create_pathgen_h5ads:
    """
    Aggregate rule to create all h5ad files and generate QC patches.
    
    This rule coordinates the creation of individual h5ad files and generates
    example patches for quality control reporting.

    """
    input:
        h5ads=get_all_h5ad_outputs
    output:
        report_patches=report([
            PROJECT_DIR / f"results/pathgen/test_patch_{i}.png" for i in range(500)
        ], category="Quality Control")
    params:
        patch_size=224
    conda: "envs/pathgen.yaml"
    resources:
        mem_mb=8000,
        slurm="cpus-per-task=1 time=01:00:00"
    script: "scripts/create_qc_patches.py"

rule all:
    """
    Default target - create all h5ad files and extract SVS metadata.
    """
    input:
        rules.create_pathgen_h5ads.output.report_patches,
        rules.extract_svs_metadata.output.metadata_txt
    default_target: True

# Testing rule for quick validation
rule test_pipeline:
    """
    Test rule to validate the pipeline setup.
    """
    input:
        rules.extract_file_ids.output.metadata_summary
    shell: """
        echo "PathGen pipeline test completed"
        echo "Check the metadata summary:"
        cat {input}
    """

rule diagnose_svs:
    """
    Diagnostic rule to extract and display SVS file metadata.
    
    Use this rule to verify magnification, pixel size, and other technical
    specifications of downloaded TCGA whole slide images.
    
    Usage: pixi run --no-progress snakemake diagnose_svs
    """
    input:
        rules.extract_svs_metadata.output.metadata_txt,
        rules.extract_svs_metadata.output.metadata_json
    shell: """
        echo "=== SVS METADATA DIAGNOSTIC REPORT ==="
        echo "Human-readable report:"
        echo "  {input[0]}"
        echo "JSON metadata:"
        echo "  {input[1]}"
        echo ""
        echo "Summary of first few files:"
        head -50 {input[0]}
        echo ""
        echo "For full report, view: {input[0]}"
        
        # Check if CSV was generated
        txt_file="{input[0]}"
        csv_file="${{txt_file%.txt}}.csv"
        if [ -f "$csv_file" ]; then
            echo ""
            echo "Summary CSV generated: $csv_file"
            echo "Preview:"
            head -10 "$csv_file" | column -t -s ','
        fi
    """
