import subprocess
import os
from pathlib import Path

PROJECT_DIR = Path(subprocess.check_output("git rev-parse --show-toplevel", shell=True).decode("utf-8").strip())
configfile: PROJECT_DIR / "config.yaml"

include: "../../shared/config.smk"
include: "../../shared/rules/dataset_processing.smk"

# Configuration for testing mode
TESTING = os.environ.get("TESTING", "0") == "1"

rule download_pathgen_metadata:
    """
    Download PathGen-1.6M metadata JSON from HuggingFace.
    
    The JSON contains WSI IDs, patch positions, captions, and GDC file IDs.
    """
    output:
        metadata_json=PROJECT_DIR / "resources" / "pathgen" / "pathgen_1.6m.json"
    params:
        huggingface_url="https://huggingface.co/datasets/jamessyx/PathGen/resolve/main/PathGen-1.6M.json"
    conda:
        "envs/pathgen.yaml"
    resources:
        mem_mb=8000,
        slurm="cpus-per-task=2 time=02:00:00"
    script: "scripts/download_pathgen_metadata.py"

checkpoint extract_file_ids:
    """
    Extract unique GDC file IDs from the PathGen metadata JSON.
    
    In testing mode, only extract file IDs for the first 2 unique WSIs.
    """
    input:
        metadata_json=rules.download_pathgen_metadata.output.metadata_json
    output:
        file_ids_list=PROJECT_DIR / "results" / "pathgen" / "gdc_file_ids.txt",
        metadata_summary=PROJECT_DIR / "results" / "pathgen" / "metadata_summary.txt"
    params:
        testing_mode=TESTING
    conda: "envs/pathgen.yaml"
    script: "scripts/extract_file_ids.py"

rule download_gdc_file:
    """
    Download individual WSI files from GDC using the gdc-client tool.

    TODO protect them
    """
    output:
        wsi_file=protected(PROJECT_DIR / "resources" / "pathgen" / "wsi_files" / "{file_id}.svs")
    resources:
        mem_mb=8000,
        slurm="cpus-per-task=2 time=04:00:00"
    shell: """
        curl -o {output.wsi_file} https://api.gdc.cancer.gov/data/{wildcards.file_id}
    """

def get_file_ids(wildcards):
    """
    Get list of file IDs to download based on checkpoint output.
    """
    checkpoint_output = checkpoints.extract_file_ids.get(**wildcards).output[0]
    with open(checkpoint_output) as f:
        file_ids = [line.strip() for line in f if line.strip()]
    
    # Return paths for all file IDs (even if empty list)
    return expand(PROJECT_DIR / "resources" / "pathgen" / "wsi_files" / "{file_id}.svs", 
                  file_id=file_ids)

rule download_all_gdc_files:
    """
    Aggregate rule to ensure all required GDC files are downloaded.
    """
    input: get_file_ids
    output: 
        complete_marker=touch(PROJECT_DIR / "results" / "pathgen" / ".gdc_downloads_complete")
    shell: """
        echo "All GDC files downloaded successfully"
        echo "Downloaded $(ls -1 {PROJECT_DIR}/resources/pathgen/wsi_files/*.svs 2>/dev/null | wc -l) WSI files"
    """

rule filter_pathgen_metadata:
    """
    Filter PathGen metadata to only include entries with successfully downloaded WSI files.
    
    In testing mode, further limit to only 2 WSIs for quick testing.
    """
    input:
        metadata_json=rules.download_pathgen_metadata.output.metadata_json,
        download_complete=rules.download_all_gdc_files.output.complete_marker
    output:
        metadata_filtered=PROJECT_DIR / "results" / "pathgen" / "pathgen_filtered.json"
    params:
        wsi_dir=PROJECT_DIR / "resources" / "pathgen" / "wsi_files",
        testing_mode=TESTING
    conda: "envs/pathgen.yaml"
    script: "scripts/filter_metadata.py"

rule extract_svs_metadata:
    """
    Extract metadata from downloaded SVS files for diagnostic purposes.
    
    This rule extracts technical specifications including magnification, pixel size,
    image dimensions, and scanner information from all downloaded SVS files.
    The metadata is saved in both JSON and human-readable formats.
    """
    input:
        download_complete=rules.download_all_gdc_files.output.complete_marker
    output:
        metadata_json=PROJECT_DIR / "results" / "pathgen" / "svs_metadata.json",
        metadata_txt=report(PROJECT_DIR / "results" / "pathgen" / "svs_metadata_report.txt", 
                           category="SVS Diagnostics", 
                           caption="Technical specifications of downloaded TCGA SVS files")
    conda: "envs/pathgen.yaml"
    resources:
        mem_mb=16000,
        slurm="cpus-per-task=2 time=02:00:00"
    script: "scripts/extract_svs_metadata.py"

rule create_pathgen_h5ads:
    """
    Create h5ad files from PathGen data following the quilt1m structure.
    
    Each WSI gets its own h5ad file with patches as observations.
    Image paths are stored in uns["image_path"] and captions in obs["natural_language_annotation"].
    Coordinates are now center-oriented (x_pixel, y_pixel = patch centers).
    """
    input:
        metadata_filtered=rules.filter_pathgen_metadata.output.metadata_filtered,
        download_complete=rules.download_all_gdc_files.output.complete_marker
    output:
        h5ads=directory(PROJECT_DIR / "results" / "pathgen" / "h5ads"),
        report_patches=report([
            PROJECT_DIR / f"results/pathgen/test_patch_{i}.png" for i in range(5)
        ], category="Quality Control")
    params:
        patch_size=224,  # Use 224x224 patches at 40x magnification (0.5 μm/pixel)
        max_patches_per_wsi=50 if not TESTING else 5  # Limit in testing mode
    conda: "envs/pathgen.yaml"
    resources:
        mem_mb=100000,
        slurm="cpus-per-task=4 time=08:00:00"
    script: "scripts/create_h5ads.py"

rule all:
    """
    Default target - create all h5ad files and extract SVS metadata.
    """
    input:
        rules.create_pathgen_h5ads.output.h5ads,
        rules.extract_svs_metadata.output.metadata_txt
    default_target: True

# Testing rule for quick validation
rule test_pipeline:
    """
    Test rule to validate the pipeline setup.
    """
    input:
        rules.extract_file_ids.output.metadata_summary
    shell: """
        echo "PathGen pipeline test completed"
        echo "Check the metadata summary:"
        cat {input}
    """

rule diagnose_svs:
    """
    Diagnostic rule to extract and display SVS file metadata.
    
    Use this rule to verify magnification, pixel size, and other technical
    specifications of downloaded TCGA whole slide images.
    
    Usage: pixi run --no-progress snakemake diagnose_svs
    """
    input:
        rules.extract_svs_metadata.output.metadata_txt,
        rules.extract_svs_metadata.output.metadata_json
    shell: """
        echo "=== SVS METADATA DIAGNOSTIC REPORT ==="
        echo "Human-readable report:"
        echo "  {input[0]}"
        echo "JSON metadata:"
        echo "  {input[1]}"
        echo ""
        echo "Summary of first few files:"
        head -50 {input[0]}
        echo ""
        echo "For full report, view: {input[0]}"
        
        # Check if CSV was generated
        txt_file="{input[0]}"
        csv_file="${{txt_file%.txt}}.csv"
        if [ -f "$csv_file" ]; then
            echo ""
            echo "Summary CSV generated: $csv_file"
            echo "Preview:"
            head -10 "$csv_file" | column -t -s ','
        fi
    """
