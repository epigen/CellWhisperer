# This pipeline processes lymphoma_cosmx 1K data variants. Provided by Warren
# It takes a high-resolution spatial transcriptomics AnnData object and an SVS image,
# and generates a gridded AnnData object with configurable spot sizes.
# Supports both lymphoma_cosmx_small (Visium-sized) and lymphoma_cosmx_small_detailed (high-res). But only detailed makes sense actually
# Alignment transformation parameters were determined through https://github.com/zinagoodlab/cosmx_he_alignment

import subprocess
from pathlib import Path

PROJECT_DIR = Path(subprocess.check_output("git rev-parse --show-toplevel", shell=True).decode("utf-8").strip())
configfile: PROJECT_DIR / "config.yaml"

include: PROJECT_DIR / "src/shared/config.smk"

# Data is already provided in resources/lymphoma_cosmx_small/. Downloaded from $OAK (CosMx_1K_CART_1__61360.svs, ALL.h5ad) to read_count_table.h5ad

# Rule order to resolve ambiguity between process_data and split_train_test for *_training/*_validation files
ruleorder: split_train_test > process_data

rule process_data:
    """
    Process lymphoma CosMx data, handling 40x magnification by scaling down to 20x.

    NOTE: may filter for minimal amount of reads per cell and based on metadata

    """
    input:
        read_count_table=PROJECT_DIR / "resources/lymphoma_cosmx_small/read_count_table.h5ad",
        image=PROJECT_DIR / "resources/lymphoma_cosmx_small/CosMx_1K_CART_1__61360.svs",
        cell_barcode_core_assignment=PROJECT_DIR / "src/datasets/lymphoma_cosmx_small/cell_barcode_core_assignment.csv",
    output:
        adata=PROJECT_DIR / config["paths"]["full_dataset"],
        image=PROJECT_DIR / config["paths"]["histo_image"],
        report_patches=report(
            [PROJECT_DIR / f"results/{{dataset}}/test_patch_{i}.png" for i in range(3)],
            category="Quality Control"
        ),
        qc_tile_plot=report(
            PROJECT_DIR / "results/{dataset}/qc_tile_plot.png",
            category="Quality Control"
        ),

    conda:
        "cellwhisperer"
    params:  
        spot_diameter_pixels=lambda wildcards: config["he_configs"][config["dataset_he_mapping"][wildcards.dataset]]["patch_size_pixels"],
        white_cutoff=lambda wildcards: config["he_configs"]["white_cutoff"],
        x_offset=0.842708,
        y_offset=1.235417,
        scale_factor=0.79488464508,
        filter_good_quality=lambda wildcards: "goodquality" in wildcards.dataset,  # Filter for good_quality cells as annotated by pathologists
        min_num_cells=5,  # filter out patches with fewer reads
        pixel_size_um=lambda wildcards: config["he_configs"][config["dataset_he_mapping"][wildcards.dataset]]["target_pixel_size"],
        small_patch_diameter_um=15.0,
        medium_patch_pixels=224,
        large_patch_pixels=448,
        max_patches_per_scale=lambda wildcards: 10 if wildcards.dataset.endswith("_singlecell") else None,
    script:
        # "notebooks/process_data.py.ipynb"   # snakemake --edit-notebook <output_file>
        "scripts/process_data.py"

rule plot_transcriptome_umap:
    """
    Generate UMAP plot of aggregated transcriptomes to assess biological signal preservation
    after patch-level aggregation.
    """
    input:
        adata=rules.process_data.output.adata
    output:
        umap_plot=report(
            PROJECT_DIR / "results/{dataset}/transcriptome_umap.png",
            category="Quality Control",
            labels={"Analysis": "Transcriptome UMAP", "Format": "plot"}
        )
    conda:
        "cellwhisperer"
    script:
        "scripts/plot_transcriptome_umap.py"

rule split_train_test:
    """
    Split the processed dataset into training and validation sets by cores.
    Validation cores are specified in params, training gets the rest.
    """
    input:
        adata=rules.process_data.output.adata
    output:
        training_adata=PROJECT_DIR / "results/{dataset}_training/full_data.h5ad",
        validation_adata=PROJECT_DIR / "results/{dataset}_validation/full_data.h5ad"
    conda:
        "cellwhisperer"
    params:
        validation_cores=["A4", "B9", "F3", "C8", "F4"]
    script:
        "scripts/split_train_test.py"

rule all:
    input:
        expand(rules.process_data.output.adata, dataset=["lymphoma_cosmx_small", "lymphoma_cosmx_small_detailed", "lymphoma_cosmx_small_singlecell", "lymphoma_cosmx_small_singlecell_corealigned", "lymphoma_cosmx_small_singlecell_goodquality"]),
        expand(rules.plot_transcriptome_umap.output.umap_plot, dataset=["lymphoma_cosmx_small", "lymphoma_cosmx_small_detailed"]),
        expand(rules.split_train_test.output.training_adata, dataset=["lymphoma_cosmx_small", "lymphoma_cosmx_small_detailed", "lymphoma_cosmx_small_singlecell", "lymphoma_cosmx_small_singlecell_corealigned", "lymphoma_cosmx_small_singlecell_goodquality"]),
        expand(rules.split_train_test.output.validation_adata, dataset=["lymphoma_cosmx_small", "lymphoma_cosmx_small_detailed", "lymphoma_cosmx_small_singlecell", "lymphoma_cosmx_small_singlecell_corealigned", "lymphoma_cosmx_small_singlecell_goodquality"])
    default_target: True

