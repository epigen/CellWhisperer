# Test configuration - single slide for fast testing
STHELAR_TEST_SLIDE_IDS = [
    "heart_s0"  # Small slide for quick testing
]

rule download_data:
    """
    Download individual STHELAR slide from S-BIAD2146 archive.
    Downloads both the zarr file for gene expression and images.zip for H&E patches.
    """
    output:
        download_flag=str(PROJECT_DIR / "resources" / "sthelar_cache" / "downloaded_{sample_id}.flag")
    params:
        sample_id="{sample_id}",
        sthelar_cache_dir=str(PROJECT_DIR / "resources" / "sthelar_cache")
    conda:
        "envs/sthelar.yaml"
    resources:  # Large downloads, may need more time
        mem_mb=50000,
        slurm="cpus-per-task=2 time=02:00:00 partition=cmackall"
    threads: 2
    script:
        "scripts/download_data.py"

rule process_data:
    """
    Process individual downloaded STHELAR slide into adata file following full_dataset_multi pattern.
    """
    input:
        download_flag=str(PROJECT_DIR / "resources" / "sthelar_cache" / "downloaded_{sample_id}.flag")
    output:
        full_data_file=str(PROJECT_DIR / config["paths"]["full_dataset_multi"]).format(dataset="sthelar", i="{sample_id}")
    params:
        sample_id="{sample_id}",
        sthelar_cache_dir=str(PROJECT_DIR / "resources" / "sthelar_cache")
    wildcard_constraints:
        dataset="sthelar"
    conda:
        "envs/sthelar.yaml"
    resources:
        mem_mb=300000,  # STHELAR data can be very large (especially brain slides)
        slurm="cpus-per-task=4 time=01:00:00 partition=cmackall"
    threads: 4
    script:
        "scripts/process_data.py"

rule all:
    input:
        expand(str(PROJECT_DIR / config["paths"]["full_dataset_multi"]), dataset="sthelar", i=STHELAR_SLIDE_IDS)
    default_target: True

rule test:
    """
    Test rule for efficient pipeline testing with a single slide.
    Usage: snakemake --cores 4 --conda-frontend mamba -s src/datasets/sthelar/Snakefile test
    """
    input:
        expand(str(PROJECT_DIR / config["paths"]["full_dataset_multi"]), dataset="sthelar", i=STHELAR_TEST_SLIDE_IDS)