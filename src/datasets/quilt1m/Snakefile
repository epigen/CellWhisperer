import subprocess
import os
from pathlib import Path

PROJECT_DIR = Path(subprocess.check_output("git rev-parse --show-toplevel", shell=True).decode("utf-8").strip())
configfile: PROJECT_DIR / "config.yaml"

include: "../../shared/config.smk"
include: "../../shared/rules/dataset_processing.smk"

scattergather:
    split=64

rule download_data:
    """
    Download individual QUILT-1M sample from HuggingFace.

    env needs rclone!
    """
    output:
        full_res=expand(PROJECT_DIR / "resources" / "quilt1m" / "fullres" / "{fn}", fn=["images_part_{i}.zip".format(i=i) for i in range(1, 11)]),
        csv=PROJECT_DIR / "resources" / "quilt1m" / "quilt_1M_lookup.csv",

        reduced_res=directory(PROJECT_DIR / "resources" / "quilt1m" / "reducedres")
    params:
        zenodo_token=lambda w: os.getenv("ZENODO_TOKEN"),
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=2 time=04:00:00 partition=cmackall"
    threads: 2
    shell: """
        echo "To be able to download the data, request access on the QUILT-1M repository"
        exit 1
        rclone copy gdrive:quilt-1m {params.full_res_folder}
        wget --header="Authorization: Bearer {params.zenodo_token}" https://zenodo.org/api/records/8239942/files-archive -O {output.reduced_res}
    """

rule unpack_data:
    """
    Unpack the downloaded QUILT-1M sample data.

    Note this also downloads quilt
    """
    input:
        full_res=expand(PROJECT_DIR / "resources" / "quilt1m" / "fullres" / "images_part_{i}.zip",i=range(1, 11)),
    output:
        full_res_unpacked=directory(PROJECT_DIR / "scratch" / "quilt1m" / "fullres"),
    resources:
        mem_mb=100000,  # Unpacking can be memory-intensive
        slurm="cpus-per-task=2 time=05:30:00 partition=cmackall"
    threads: 2
    shell: """
    echo "Unpacking QUILT-1M data..."
    for f in {input.full_res}; do
        unzip -o -j -d {output.full_res_unpacked} $f
    done
    """

rule filter_metadata:
    input:
        metadata=PROJECT_DIR / "resources" / "quilt1m" / "quilt_1M_lookup.csv"  # TODO will reside in fullres later
    output:
        metadata_filtered=PROJECT_DIR / "results" / "quilt1m" / "quilt_1M_lookup.csv"
    conda:
        "cellwhisperer"
    script:
        "scripts/filter_metadata.py"

rule define_crops:
    """
    Derive h5ad files with the crops indicated in the the unpacked QUILT-1M dataset.

    NOTE: There are two levels of redundancy here: quilt1m already defines 10 captions per image. And we now make 10 crops out of each of them... It's super inefficient, because we create 10x more h5ads than needed. Keeping as is anyways though..
    """
    input:
        full_res_unpacked=rules.unpack_data.output.full_res_unpacked,
        metadata_filtered=lambda wildcards: rules.aggregate_curated_metadata.output.curated_metadata if "curated" in wildcards.dataset else rules.filter_metadata.output.metadata_filtered,
    output:
        cropped_images=directory(PROJECT_DIR / "results" / "{dataset}" / "h5ads"),
        report_patches=report(
            [PROJECT_DIR / f"results/{{dataset}}/test_patch_{i}.png" for i in range(5)],
            category="Quality Control"
        )
    params:
        crop_size=224,  # Example crop size, adjust as needed
        num_crops_per_image=10  # Randomly sampled from within the 50% center piece of the image
    conda:
        "cellwhisperer"
    resources:
        mem_mb=100000,  # Image processing can be memory-intensive
        slurm="cpus-per-task=2 time=05:30:00 partition=cmackall"
    threads: 2
    script:
        "scripts/define_crops.py"

rule prepare_curation_splits:
    """
    Split CSV metadata into batches for parallel processing
    """
    input:
        metadata_filtered=rules.filter_metadata.output.metadata_filtered
    output:
        splits=scatter.split(PROJECT_DIR / "results" / "quilt1m_curated" / "splits" / "{scatteritem}.csv")
    run:
        import pandas as pd
        
        # Read the filtered metadata
        df = pd.read_csv(input.metadata_filtered)
        
        # Split rows across scatteritems
        for split_fn in output.splits:
            split_i, split_n = map(int, Path(split_fn).stem.split('-of-'))
            split_i -= 1  # 0-indexing
            
            # Take every split_n-th row starting from split_i
            split_df = df.iloc[split_i::split_n]
            
            Path(split_fn).parent.mkdir(parents=True, exist_ok=True)
            split_df.to_csv(split_fn, index=False)

rule process_curation_batch:
    """
    Process a batch of CSV metadata with LLM curation
    """
    input:
        split_csv=PROJECT_DIR / "results" / "quilt1m_curated" / "splits" / "{scatteritem}.csv",
        prompt_file=PROJECT_DIR / "src" / "datasets" / "quilt1m" / "prompts" / "curation.txt"
    output:
        processed_csv=PROJECT_DIR / "results" / "quilt1m_curated" / "processed" / "{scatteritem}.csv"
    log:
        PROJECT_DIR / "results" / "quilt1m_curated" / "logs" / "{scatteritem}.log"
    params:
        model_path="openai/gpt-oss-120b", # "meta-llama/Llama-4-Scout-17B-16E-Instruct",  # openai/gpt-oss-120b
        quantization=None,  # "fp8"
        max_num_seqs=16
    conda:
        "../../../envs/vllm.yaml"
    resources:
        mem_mb=100000,
        slurm=slurm_gres("large")
    threads: 8
    script:
        "scripts/curation_processing.py"

rule aggregate_curated_metadata:
    """
    Aggregate all processed CSV splits into a single curated metadata file
    """
    input:
        processed_csvs=gather.split(PROJECT_DIR / "results" / "quilt1m_curated" / "processed" / "{scatteritem}.csv")
    output:
        curated_metadata=PROJECT_DIR / "results" / "quilt1m_curated" / "quilt_1M_lookup_curated.csv"
    run:
        import pandas as pd

        # Read and concatenate all processed CSVs
        all_dfs = []
        for csv_file in input.processed_csvs:
            if Path(csv_file).exists() and Path(csv_file).stat().st_size > 0:
                df = pd.read_csv(csv_file)
                if not df.empty:
                    all_dfs.append(df)

        if all_dfs:
            combined_df = pd.concat(all_dfs, ignore_index=True)
            combined_df.to_csv(output.curated_metadata, index=False)
        else:
            # Create empty file if no data
            pd.DataFrame().to_csv(output.curated_metadata, index=False)

rule all:
    input:
        quilt1m=expand(rules.define_crops.output.cropped_images, dataset=["quilt1m", "quilt1m_curated"]),
    default_target: True
