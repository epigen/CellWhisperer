
from pathlib import Path
import numpy as np
from snakemake.remote.HTTP import RemoteProvider as HTTPRemoteProvider
HTTP = HTTPRemoteProvider()

# Download and preprocess the Tabula Sapiens dataset

PROJECT_DIR = Path(workflow.basedir).resolve().parents[2]
configfile: PROJECT_DIR / "config.yaml"

H5AD_URL = "https://figshare.com/ndownloader/files/40067134"

rule all:
    input:
        read_count_table=PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="gut_cell_atlas")


rule read_count_table:
    input:
        raw=HTTP.remote("https://cellgeni.cog.sanger.ac.uk/gutcellatlas/Full_obj_raw_counts_nosoupx_v2.h5ad", keep_local=True),
        normed=HTTP.remote("https://cellgeni.cog.sanger.ac.uk/gutcellatlas/Full_obj_log_counts_soupx_v2.h5ad", keep_local=True),
    output:
        rules.all.input.read_count_table
    conda:
        "cellwhisperer"
    notebook:
        "notebooks/read_count_table.py.ipynb"

