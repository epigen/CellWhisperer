from pathlib import Path
import numpy as np

# Download and preprocess the Tabula Sapiens dataset

PROJECT_DIR = Path(workflow.basedir).resolve().parents[2]
configfile: PROJECT_DIR / "config.yaml"

H5AD_URL = "https://figshare.com/ndownloader/files/40067134"

rule all:
    input:
        PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens"),
        PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens_100_cells_per_type"),

        #PROJECT_DIR / config["paths"]["structured_annotations"].format(dataset="immgen")

# TODO need to run `data.var.rename(columns={"gene_symbol": "gene_name"}, inplace=True)`
rule download_data:
    """
    """
    output:
        read_count_table=PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens"),
    shell:
        """
        wget -O {output.read_count_table}.zip {H5AD_URL}
        unzip {output.read_count_table}.zip -d $(dirname {output.read_count_table})
        mv $(dirname {output.read_count_table})/TabulaSapiens.h5ad {output.read_count_table}
        rm {output.read_count_table}.zip
        """

rule subsample_data:
    """
    """
    input:
        read_count_table_full=PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens"),
    output:
        read_count_table_100_cells_per_type=PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens_100_cells_per_type"),
        read_count_table_full=PROJECT_DIR / config["paths"]["read_count_table"].format(dataset="tabula_sapiens"),
        structured_annotations_100percelltype = PROJECT_DIR / config["paths"]["structured_annotations"].format(dataset="tabula_sapiens_100_cells_per_type"),
        structured_annotations_full = PROJECT_DIR / config["paths"]["structured_annotations"].format(dataset="tabula_sapiens"),
    conda:
        # PROJECT_DIR / "envs" / "main.yaml"
        "single-cellm"
    script:
        "scripts/subsample_data.py"
