# CosMx Large pipeline for 11 TMAs (8 files due to joint scanning)
# This pipeline processes lymphoma_cosmx_large data with multiple TMAs.
# It takes a combined h5ad file and multiple TIFF images, processes each TMA separately,
# and generates a multi-dataset following the hest1k pattern.
# Alignment transformation parameters from https://github.com/zinagoodlab/cosmx_he_alignment

import subprocess
import pandas as pd
from pathlib import Path

PROJECT_DIR = Path(subprocess.check_output("git rev-parse --show-toplevel", shell=True).decode("utf-8").strip())
configfile: PROJECT_DIR / "config.yaml"

include: PROJECT_DIR / "src/shared/config.smk"

# Dataset name
DATASET = "lymphoma_cosmx_large"

# Configuration: Set to True when TIFF images are available
DROP_LOW_QUALITY_TMAS = False  # Try False as well

# Mapping from grouped sample IDs to individual TMA IDs in the h5ad
# The h5ad contains individual TMAs, but alignment.csv groups them for joint processing
TMA_GROUPING = {
    "TMA1": ["TMA1"],
    "TMA2": ["TMA2"],
    "TMA3": ["TMA3"],
    "TMA4": ["TMA4-Sec1", "TMA4-Sec2"],  # TMA4 was scanned in two sections
    "TMA5": ["TMA5"],
    "TMA11_12": ["TMA11", "TMA12"],      # Joint scan
    "TMA13_14": ["TMA13", "TMA14"],      # Joint scan
    "TMA15_16": ["TMA15", "TMA16"],      # Joint scan
}

LOW_QUALITY_TMAS = ["TMA1" "TMA11_12"]

if DROP_LOW_QUALITY_TMAS:
    TMA_GROUPING = {
        key: value for key, value in TMA_GROUPING.items() if key not in LOW_QUALITY_TMAS
    }

# Derive sample IDs from TMA grouping keys
SAMPLE_IDS = list(TMA_GROUPING.keys())

# Load alignment parameters from CSV
ALIGNMENT_DF = pd.read_csv(PROJECT_DIR / f"src/datasets/{DATASET}/alignment_values/alignment.csv").set_index("sample")

# Source location for SVS images
RAW_DATA_BASE = "/oak/stanford/groups/zinaida/CAR_T_data_warehouse/CosMX/stanford_CART_TMA/data"
SAMPLE_TO_RAW_EXPR = {
    "TMA2": f"{RAW_DATA_BASE}/CART_TMA2_20_08_2025_0_19_00_203/flatFiles/CarTTMA2/CarTTMA2_exprMat_file.csv.gz",
    "TMA3": f"{RAW_DATA_BASE}/CART_TMA3_20_08_2025_0_21_28_874/flatFiles/CarTTMA3/CarTTMA3_exprMat_file.csv.gz",
    "TMA4": f"{RAW_DATA_BASE}/CART_TMA4_12_09_2025_10_19_26_839/flatFiles/CARTTMA4/CARTTMA4_exprMat_file.csv.gz",
    "TMA5": f"{RAW_DATA_BASE}/CART_TMA5_12_09_2025_10_20_16_938/flatFiles/CARTTMA5/CARTTMA5_exprMat_file.csv.gz",
    "TMA13_14": f"{RAW_DATA_BASE}/Car_T_13_14_v202_19_11_2025_16_05_34_581/flatFiles/CarT1314/CarT1314_exprMat_file.csv.gz",
    "TMA15_16": f"{RAW_DATA_BASE}/Car_T_15_16_v202_20_06_2025_19_13_25_525/CarT1516/CarT1516_exprMat_file.csv.gz",
}

IMAGE_SOURCE_BASE = "/oak/stanford/groups/zinaida/CAR_T_data_warehouse/CosMX/stanford_CART_TMA/CosMx_CAR_T_post_run_HE"
SAMPLE_TO_IMAGE = {
    "TMA1": ("Batch-1", "CosMx_6K_CART_1__61356.svs"),
    "TMA2": ("Batch-2", "CosMx_6K_CART_2_40X-2025-11-14-11.46.42"),
    "TMA3": ("Batch-2", "CosMx_6K_CART_3_40X-2025-11-14-11.24.48"),
    "TMA4": ("Batch-2", "CosMx_6K_CART_4_40X-2025-11-14-11.18.17"),
    "TMA5": ("Batch-2", "CosMx_6K_CART_5_40X-2025-11-14-11.21.44"),
    "TMA11_12": ("Batch-1", "CosMx_6K_CART_11_12__61358.svs"),
    "TMA13_14": ("Batch-1", "CosMx_6K_CART_13_14__61357.svs"),
    "TMA15_16": ("Batch-1", "CosMx_6K_CART_15_16__61355.svs"),
}


rule copy_images:
    """
    Copy SVS images from source directory to resources.
    Maps sample IDs (TMA1, TMA2, etc.) to actual image filenames.
    Images can be loaded with openslide even without .svs extension.
    """
    input:
        image=lambda w: f"{IMAGE_SOURCE_BASE}/{SAMPLE_TO_IMAGE[w.sample][0]}/{SAMPLE_TO_IMAGE[w.sample][1]}"
    output:
        image=PROJECT_DIR / f"resources/{DATASET}/images/{{sample}}.svs"
    shell:
        "cp {input.image} {output.image}"


rule disentangle_tmas:
    """
    Split combined h5ad file into separate per-TMA h5ad files.

    This file was generated by Eric through integration across all TMAs 
    for batch effect removal using scTransform.

    The h5ad contains individual TMAs (TMA1, TMA2, ..., TMA16), which are
    grouped according to alignment.csv:
    - TMA11 + TMA12 → TMA11_12
    - TMA13 + TMA14 → TMA13_14
    - TMA15 + TMA16 → TMA15_16
    - TMA4-Sec1 + TMA4-Sec2 → TMA4
    """
    input:
        combined_h5ad=PROJECT_DIR / f"resources/{DATASET}/adata_combined_seurat.h5ad"  # copied from /oak/stanford/groups/zinaida/eric/cart_cosmx/exportedMtx/all_cells_sct/adata_combined_seurat.h5ad
    output:
        output_dir=directory(PROJECT_DIR / f"resources/{DATASET}/per_tma_h5ads"),
        h5ad_files=expand(
            PROJECT_DIR / f"resources/{DATASET}/per_tma_h5ads/{{sample}}.h5ad",
            sample=SAMPLE_IDS
        )
    params:
        tma_column="tmaID",  # Column name in adata.obs that identifies TMA
        sample_ids=SAMPLE_IDS,
        tma_grouping=TMA_GROUPING  # Mapping from sample IDs to individual TMA IDs
    conda:
        "cellwhisperer"
    script:
        "scripts/disentangle_tmas.py"


rule process_data:
    """
    Process individual TMA CosMx data, handling 40x magnification by scaling down to 20x.

    Uses per-TMA alignment parameters from alignment.csv with:
    - Pixel-based offsets (not mm-based)
    - Separate X/Y scale factors

    Note: TIFF images are optional (controlled by USE_TIFF_IMAGES flag).
    """
    input:
        read_count_table=PROJECT_DIR / f"resources/{DATASET}/per_tma_h5ads/{{sample}}.h5ad",
        image=rules.copy_images.output.image
    output:
        adata=PROJECT_DIR / "results/{dataset}_{sample}/full_data.h5ad",
        report_patches=report(
            [PROJECT_DIR / "results/{{dataset}}/{{sample}}/test_patch_{i}.png".format(i=i) for i in range(3)],
            category="Quality Control"
        ),  # old path still, but no problem..
        qc_tile_plot=report(
            PROJECT_DIR / "results/{dataset}/{sample}/qc_tile_plot.png",
            category="Quality Control"
        ),
    wildcard_constraints:
        dataset=DATASET
    conda:
        "cellwhisperer"
    resources:
        slurm="cpus-per-task=32"  # run with 32/64. It *is* muuuch faster
    params:
        sample="{sample}",
        x_offset_pixels=lambda w: int(ALIGNMENT_DF.loc[w.sample, "x_offset_pixels"]),
        y_offset_pixels=lambda w: int(ALIGNMENT_DF.loc[w.sample, "y_offset_pixels"]),
        scale_factor_x=lambda w: float(ALIGNMENT_DF.loc[w.sample, "scale_factor_x"]),
        scale_factor_y=lambda w: float(ALIGNMENT_DF.loc[w.sample, "scale_factor_y"]),
        spot_diameter_pixels=config["he_configs"]["single_cell_40x_pixels"],  # NOTE: not really necessary here as we only extract cells during training
        white_cutoff=lambda w: config["he_configs"]["white_cutoff"],
        brightness_threshold=215,  # Threshold for filtering bright cells (value channel intensity)
        min_num_cells=5,  # filter out patches with fewer cells
        pixel_size_um=lambda w: config["he_configs"]["detailed_resolution"]["target_pixel_size"],
        small_patch_diameter_um=15.0,
        medium_patch_pixels=224,
        large_patch_pixels=448,
        max_patches_per_scale=None,
    script:
        "scripts/process_data.py"


rule filter_good_quality:
    """Filter out low-quality cores using the good_quality annotation."""
    input:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}/full_data.h5ad"
    output:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}_hqcores/full_data.h5ad"
    conda:
        "cellwhisperer"
    script:
        "scripts/filter_good_quality.py"


rule filter_fna:
    """Filter out fine needle aspirate cores (TISS_prefix == 'SHF')."""
    input:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}/full_data.h5ad"
    output:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}_nofna/full_data.h5ad"
    conda:
        "cellwhisperer"
    script:
        "scripts/filter_fna.py"


ruleorder: replace_with_raw_counts > process_data

rule replace_with_raw_counts:
    """Replace SCTransform corrected counts in X with raw read counts from CosMx flat files."""
    input:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}/full_data.h5ad",
        raw_expr=lambda w: SAMPLE_TO_RAW_EXPR[w.sample]
    output:
        adata=PROJECT_DIR / f"results/{DATASET}_{{sample}}_raw/full_data.h5ad"
    conda:
        "cellwhisperer"
    resources:
        mem_mb=40000,
    script:
        "scripts/replace_with_raw_counts.py"


rule symlink_to_joint_dataset:
    """
    Optionally, we also integrate this into a single dataset for conviencen
    """
    input:
        rules.process_data.output.adata
    output:
        PROJECT_DIR / "results/{dataset}/h5ads/full_data_{sample}.h5ad"
    shell: """
        ln -s {input} {output}
    """


rule all:
    input:
        # Process all individual TMAs into multi-dataset format
        expand(
            rules.symlink_to_joint_dataset.output,
            dataset=DATASET,
            sample=SAMPLE_IDS
        ),
    default_target: True

