rule download_data:
    output:
        download_dir=temporary(directory(PROJECT_DIR / "resources" / "tcga_skcm_tmp_download")),
        dataset_small=PROJECT_DIR / "resources" / "tcga_skcm_small" / "read_count_table.h5ad",
        report_patches=report(
            [PROJECT_DIR / f"results/tcga_skcm_small/test_patch_{i}.png" for i in range(3)],
            category="Quality Control"
        )
        # combined_dataset_medium=PROJECT_DIR / "resources" / "tcga_skcm_medium" / "read_count_table.h5ad"
    params:
        huggingface_token=os.getenv("HUGGINGFACE_TOKEN"),
        sample_id_small="TCGA_SKCM/FFPE/TCGA-D9-A3Z3-06Z-00-DX1.C4820632-C64D-4661-94DD-9F27F75519C3.h5ad.gz",
        # sample_ids_medium=SAMPLE_IDS
    conda:
        "cellwhisperer"
    resources:
        mem_mb=50000,
    script:
        "scripts/download_data.py"


rule compute_umap_neighbors:
    """
    # copied from fig2...smk (TODO DRY-refactor)
    """
    input:
        processed_dataset=PROJECT_DIR / config["paths"]["model_processed_dataset"],
        raw_read_count_table=PROJECT_DIR / config["paths"]["read_count_table"]
    output:
        umap=PROJECT_DIR / "results" / "{dataset,[^/]+}" / "{model}" / "X_umap_on_neighbors.npz"
    conda:
        "cellwhisperer"
    resources:
        mem_mb=200000,
        slurm="cpus-per-task=2"
    log:
        notebook="logs/compute_umap_neighbors_{dataset}_{model}.ipynb"
    notebook:
        "../../figures/notebooks/compute_umap_neighbors.py.ipynb"


rule plot_umap_with_label:
    """
    """
    input:
        processed_dataset=PROJECT_DIR / config["paths"]["model_processed_dataset"],
        raw_read_count_table=str(PROJECT_DIR / config["paths"]["read_count_table"]),
        mpl_style=ancient(PROJECT_DIR / config["plot_style"]),
        umap=rules.compute_umap_neighbors.output.umap
    output:
        plot=PROJECT_DIR / "results" / "plots" / "umap" / "{dataset}" / "{model}" / "plot.png",
    params:
        label="predicted_label",
    conda:
        "cellwhisperer"
    resources:
        mem_mb=350000,
        slurm="cpus-per-task=2"
    log:
        notebook="logs/plot_term_search_results_{dataset}_{model}.ipynb"
    notebook:
        "notebooks/plot_umap_with_label.py.ipynb"

rule all:
    input:
        expand(rules.plot_umap_with_label.output.plot, dataset=["tcga_skcm_small"], model=[config["model_name_path_map"]["cellwhisperer_geneformer"]])
    default_target: True
