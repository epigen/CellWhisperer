# HEST benchmark evaluation pipeline for CellWhisperer
# Three-step pipeline per dataset: (1) patch extraction (2) inference (3) evaluation

include: "../../shared/config.smk"
include: "../../shared/rules/dataset_processing.smk"

# Define datasets to benchmark
HEST_DATASETS = ["IDC", "PRAD", "PAAD", "SKCM", "COAD", "READ", "CCRCC", "HCC", "LUNG", "LYMPH_IDC"]

# Path structure with dataset-specific folders using config paths
HEST_RESULTS = PROJECT_DIR / config["paths"]["hest_benchmark"]["results"]
HEST_MODEL_RESULTS = HEST_RESULTS / "{model}"
HEST_DATASET_RESULTS = HEST_MODEL_RESULTS / "{dataset}"

# Data paths from config
HEST_DATA_ROOT = PROJECT_DIR / config["paths"]["hest_benchmark"]["data_root"]
HEST_EMBED_ROOT = PROJECT_DIR / config["paths"]["hest_benchmark"]["embed_root"]
HEST_PRED_ROOT = PROJECT_DIR / config["paths"]["hest_benchmark"]["pred_root"]

rule prepare_hest_data:
    """
    Prepare HEST benchmark data for a specific dataset using HEST conda environment

    This step downloads and prepares the HEST benchmark dataset
    with pre-extracted patches and split files.
    """
    input:
        config_file=PROJECT_DIR / "src/figures/config/bench_config.yaml"
    output:
        dataset_dir=directory(HEST_DATA_ROOT / "{dataset}")
    conda:
        "hest"
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=2",
        runtime=120  # 2 hours for downloading
    script:
        "../scripts/prepare_hest_data.py"

rule spotwhisperer_inference:
    """
    Run SpotWhisperer inference on HEST patches for a specific dataset
    using cellwhisperer conda environment

    This step processes HEST patches through the SpotWhisperer model
    to generate embeddings that will be used for evaluation.


    TODO: WARNING:root:Sample TENX117 (and TENX115) already processed, skipping duplicate.

    """
    input:
        model=PROJECT_DIR / config["paths"]["jointemb_models"] / "{model}.ckpt",
        dataset_dir=HEST_DATA_ROOT / "{dataset}"
    output:
        embeddings_dir=directory(HEST_EMBED_ROOT / "{dataset}" / "{model}")
    params:
        batch_size=64,
    conda:
        "cellwhisperer"
    resources:
        mem_mb=500000,
        slurm=slurm_gres(),
        runtime=480  # 8 hours
    threads: 1
    script:
        "../scripts/run_spotwhisperer_inference.py"

rule hest_evaluation:
    """
    Run HEST evaluation using pre-computed SpotWhisperer embeddings for a specific dataset

    This step performs the actual benchmark evaluation using HEST's regression pipeline
    with embeddings generated by SpotWhisperer in the previous step.

    NOTE: The paths etc. are not very elegantly used here, but it works for now.
    """
    input:
        dataset_dir=HEST_DATA_ROOT / "{dataset}",
        embeddings_dir=HEST_EMBED_ROOT / "{dataset}" / "{model}",
    output:
        results_dir=directory(HEST_PRED_ROOT / "{model}" / "{dataset}")
    params:
        batch_size=128,
        # evaluation parameters
        dimreduce=None, # "PCA"
        latent_dim=256,  # for PCA if enabled
        normalize=True,
        method="ridge",  # regression method
        seed=1
    conda:
        "hest"
    resources:
        mem_mb=200000,
        slurm="cpus-per-task=8",
        runtime=240  # 4 hours for full evaluation with cross-validation
    script:
        "../scripts/run_hest_evaluation.py"


rule aggregate_hest_results:
    """
    Aggregate results from all datasets into a single summary
    """
    input:
        results_dirs=expand(rules.hest_evaluation.output.results_dir,
               dataset=HEST_DATASETS,
               allow_missing=True
        )
    output:
        aggregated_summary=HEST_MODEL_RESULTS / "aggregated_benchmark_summary.json"
    params:
        datasets=HEST_DATASETS
    conda:
        "cellwhisperer"
    resources:
        mem_mb=10000,
        slurm="cpus-per-task=1"
    script:
        "../scripts/aggregate_hest_results.py"

# Main rule to run complete HEST benchmark across all datasets
rule hest_benchmark_all:
    input:
        expand(
            HEST_MODEL_RESULTS / "aggregated_benchmark_summary.json",
            model=config["model_name_path_map"]["spotwhisperer"]
        )
    default_target: True
