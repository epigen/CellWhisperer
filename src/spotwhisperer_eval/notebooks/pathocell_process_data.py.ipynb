{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Process PathoCell Data into CellWhisperer Format\n",
    "\n",
    "This notebook processes the PathoCell dataset from HDF5 format to AnnData format.\n",
    "It extracts the first TMA and formats it similar to the lymphoma_cosmx_small dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import h5py\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import anndata\n",
    "from pathlib import Path\n",
    "import json\n",
    "import logging\n",
    "from PIL import Image\n",
    "import tifffile\n",
    "\n",
    "logging.basicConfig(level=logging.INFO)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get paths from snakemake\n",
    "data_dir = Path(snakemake.input.data_dir)\n",
    "output_adata_path = Path(snakemake.output.adata)\n",
    "output_image_path = Path(snakemake.output.image)\n",
    "output_metadata_path = Path(snakemake.output.metadata)\n",
    "\n",
    "logging.info(f\"Reading PathoCell data from {data_dir}\")\n",
    "logging.info(f\"Will save processed data to {output_adata_path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Find the HDF5 file in the pathocell_hdf directory\n",
    "hdf_dir = data_dir / \"pathocell_hdf\"\n",
     "h5_files = list(hdf_dir.glob(\"*.h5\"))\n",
     "\n",
     "if not h5_files:\n",
     "    h5_files = list(hdf_dir.glob(\"*.hdf5\"))\n",
     "\n",
     "if not h5_files:\n",
     "    h5_files = list(hdf_dir.glob(\"*.hdf\"))\n",
     "\n",
     "if not h5_files:\n",
     "    raise FileNotFoundError(f\"No HDF5 files found in {hdf_dir}\")\n",
     "\n",
     "# Look for the TMA files (there should be 2 TMAs based on the paper)\n",
     "# We'll process the first one (TMA 1)\n",
     "tma_files = sorted([f for f in h5_files if 'tma' in f.name.lower() or 'TMA' in f.name])\n",
     "\n",
     "if not tma_files:\n",
     "    # If no specific TMA files, use the first H5 file\n",
     "    tma_files = sorted(h5_files)\n",
     "\n",
     "if not tma_files:\n",
     "    raise FileNotFoundError(f\"No suitable HDF files found in {hdf_dir}\")\n",
     "\n",
     "h5_path = tma_files[0]\n",
     "logging.info(f\"Processing HDF5 file: {h5_path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Read the HDF5 file to understand its structure\n",
    "with h5py.File(h5_path, 'r') as f:\n",
    "    logging.info(f\"Keys in HDF5 file: {list(f.keys())}\")\n",
    "    \n",
    "    # Extract images and masks\n",
    "    # img: H&E image (3, H, W), gt_inst: instance segmentation (1, H, W), gt_ct: cell type labels (1, H, W)\n",
    "    images = f['img'][:] if 'img' in f else None\n",
    "    masks = f['gt_inst'][:] if 'gt_inst' in f else None\n",
    "    \n",
    "    # Extract cell type labels\n",
         "    labels = f['gt_ct'][:] if 'gt_ct' in f else None\n",
    "\n",
    "\n",
    "\n",
    "    else:\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "    \n",
    "    # Get cell type names (14 types according to paper)\n",
    "    if 'cell_type_names' in f:\n",
    "        cell_type_names = [name.decode('utf-8') if isinstance(name, bytes) else name \n",
    "                          for name in f['cell_type_names'][:]]\n",
    "    elif 'class_names' in f:\n",
    "        cell_type_names = [name.decode('utf-8') if isinstance(name, bytes) else name \n",
    "                          for name in f['class_names'][:]]\n",
    "    else:\n",
    "        # PathoCellBench cell types from the official dataset\n",
    "        cell_type_names = [\n",
    "            \"background\",\n",
     "            \"B cells\", \"macrophages\", \"nerves\", \"dendritic cells\", \"plasma cells\",\n",
    "            \"granulocytes\", \"tumor cells\", \"T cells\", \"stroma\", \"adipocytes\",\n",
    "            \"vasculature\", \"smooth muscle\", \"NK cells\"\n",
    "        ]\n",
    "    \n",
    "    logging.info(f\"Found {len(cell_type_names)} cell types: {cell_type_names}\")\n",
    "    \n",
    "    # Get spatial information if available\n",
    "    if 'coordinates' in f:\n",
    "        coordinates = f['coordinates'][:]\n",
    "    elif 'centroids' in f:\n",
    "        coordinates = f['centroids'][:]\n",
    "    else:\n",
    "        coordinates = None\n",
    "\n",
    "logging.info(f\"Images shape: {images.shape if images is not None else 'None'}\")\n",
    "logging.info(f\"Masks shape: {masks.shape if masks is not None else 'None'}\")\n",
    "logging.info(f\"Labels shape: {labels.shape if labels is not None else 'None'}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "    # Process the PathoCellBench data\n",
    "    # The data format is (C, H, W) for images and (1, H, W) for masks/labels\n",
    "    # Convert to (H, W, C) format for easier processing\n",
    "    \n",
     "if images is not None:\n",
     "    # Convert from (3, H, W) to (H, W, 3)\n",
     "    image = np.transpose(images, (1, 2, 0))\n",
     "else:\n",
     "    raise ValueError(\"No image data found in HDF5 file\"),\n",
    "    \n",
     "if masks is not None:\n",
     "    # Remove the first dimension: (1, H, W) -> (H, W)\n",
     "    mask = masks[0]\n",
     "else:\n",
     "    raise ValueError(\"No mask data found in HDF5 file\")\n",
     "    \n",
     "if labels is not None:\n",
     "    # Remove the first dimension: (1, H, W) -> (H, W)\n",
     "    label_map = labels[0]\n",
     "else:\n",
     "    label_map = None"\n",
    "\n",
    "logging.info(f\"Processing image shape {image.shape}, mask shape {mask.shape}\")\n",
    "\n",
    "# Extract cell centroids from the mask\n",
    "unique_cell_ids = np.unique(mask)\n",
    "unique_cell_ids = unique_cell_ids[unique_cell_ids > 0]  # Remove background (0)\n",
    "\n",
    "logging.info(f\"Found {len(unique_cell_ids)} cells\")\n",
    "\n",
    "# Calculate cell centroids and extract labels\n",
    "cell_data = []\n",
    "for cell_id in unique_cell_ids:\n",
    "    cell_mask = (mask == cell_id)\n",
    "    coords = np.where(cell_mask)\n",
     "    \n",
     "    if len(coords[0]) == 0:  # Skip empty masks\n",
     "        continue"\n",
    "    \n",
    "    # Calculate centroid\n",
    "    y_pixel = coords[0].mean()\n",
    "    x_pixel = coords[1].mean()\n",
    "    \n",
    "    # Get cell type label from the label map\n",
    "    if label_map is not None:\n",
    "        # Get the label at the cell centroid position\n",
    "        cell_label_idx = label_map[coords[0][0], coords[1][0]]\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "        \n",
    "        cell_type = cell_type_names[int(cell_label_idx)] if cell_label_idx < len(cell_type_names) else \"unknown\"\n",
    "    else:\n",
    "        cell_type = \"unknown\"\n",
    "    \n",
    "    cell_data.append({\n",
    "        'cell_id': int(cell_id),\n",
    "        'x_pixel': x_pixel,\n",
    "        'y_pixel': y_pixel,\n",
    "        'cell_type': cell_type\n",
    "    })\n",
    "\n",
    "# Create DataFrame\n",
    "cells_df = pd.DataFrame(cell_data)\n",
    "logging.info(f\"Created cell dataframe with {len(cells_df)} cells\")\n",
    "logging.info(f\"Cell type distribution:\\n{cells_df['cell_type'].value_counts()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create AnnData object\n",
    "# For PathoCellBench, we don't have gene expression data, so we create a minimal AnnData\n",
    "# The key information is the spatial coordinates and cell type labels\n",
    "\n",
    "# Create dummy expression matrix (all zeros since we're doing image-based classification)\n",
    "n_cells = len(cells_df)\n",
    "n_genes = 1  # Minimal gene set\n",
    "X = np.zeros((n_cells, n_genes), dtype=np.float32)\n",
    "\n",
    "# Create obs DataFrame\n",
    "obs = pd.DataFrame({\n",
    "    'cell_id': cells_df['cell_id'].values,\n",
    "    'x_pixel': cells_df['x_pixel'].values,\n",
    "    'y_pixel': cells_df['y_pixel'].values,\n",
    "    'cell_type': cells_df['cell_type'].values,\n",
    "    'x_array': (cells_df['x_pixel'] / 224).astype(int).values,  # Default patch size\n",
    "    'y_array': (cells_df['y_pixel'] / 224).astype(int).values,\n",
    "    'n_cells': 1,  # Single-cell level\n",
    "})\n",
    "obs.index = [f\"cell_{i}\" for i in range(n_cells)]\n",
    "\n",
    "# Create var DataFrame\n",
    "var = pd.DataFrame({'gene_name': ['dummy_gene']}, index=['dummy_gene'])\n",
    "\n",
    "# Create AnnData\n",
    "adata = anndata.AnnData(X=X, obs=obs, var=var)\n",
    "\n",
    "# Add spatial coordinates\n",
    "adata.obsm['spatial'] = cells_df[['x_pixel', 'y_pixel']].values\n",
    "\n",
    "# Add image to uns (similar to lymphoma_cosmx_small format)\n",
    "# Downsample image for visualization\n",
    "from PIL import Image\n",
    "    \n",
     "# Convert image to uint8 format (0-255)\n",
     "if image.dtype != np.uint8:\n",
     "    # Normalize to 0-255 range\n",
     "    image_min = image.min()\n",
     "    image_max = image.max()\n",
     "    if image_max > image_min:\n",
     "        image_norm = ((image - image_min) / (image_max - image_min) * 255).astype(np.uint8)\n",
     "    else:\n",
     "        image_norm = np.zeros_like(image, dtype=np.uint8)\n",
     "else:\n",
     "    image_norm = image\n",
     "\n",
     "img_pil = Image.fromarray(image_norm)"\n",
    "max_size = 2000\n",
    "if img_pil.size[0] > max_size or img_pil.size[1] > max_size:\n",
    "    img_pil.thumbnail((max_size, max_size))\n",
    "img_np = np.array(img_pil)\n",
    "scale_factor_img = img_np.shape[0] / image.shape[0]\n",
    "\n",
    "library_id = \"pathocell_tma1\"\n",
    "adata.uns['spatial'] = {\n",
    "    library_id: {\n",
    "        'images': {'hires': img_np},\n",
    "        'scalefactors': {\n",
    "            'tissue_hires_scalef': scale_factor_img,\n",
    "            'spot_diameter_fullres': 224,  # Default patch size\n",
    "        },\n",
    "        'metadata': {'library_id': library_id},\n",
    "    }\n",
    "}\n",
    "\n",
    "adata.uns['pixel_size'] = 0.5  # Approximate pixel size in micrometers\n",
    "adata.uns['dataset'] = 'pathocell_tma1'\n",
    "adata.uns['image_path'] = str(output_image_path)\n",
    "\n",
    "logging.info(f\"Created AnnData with {adata.n_obs} cells and {adata.n_vars} genes\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save the image as TIFF (SVS format is proprietary, so we use TIFF)\n",
    "output_image_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Convert to RGB if grayscale\n",
    "if len(image.shape) == 2:\n",
    "    image_rgb = np.stack([image, image, image], axis=2)\n",
    "elif image.shape[2] == 1:\n",
    "    image_rgb = np.repeat(image, 3, axis=2)\n",
    "else:\n",
    "    image_rgb = image\n",
    "\n",
    "tifffile.imwrite(output_image_path, image_rgb, photometric='rgb')\n",
    "logging.info(f\"Saved image to {output_image_path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save metadata\n",
    "metadata = {\n",
    "    'dataset': 'PathoCellBench',\n",
    "    'tma_id': 'TMA1',\n",
    "    'fov_idx': fov_idx,\n",
    "    'n_cells': int(n_cells),\n",
    "    'n_cell_types': len(cell_type_names),\n",
    "    'cell_type_names': cell_type_names,\n",
    "    'image_shape': list(image.shape),\n",
    "    'cell_type_distribution': cells_df['cell_type'].value_counts().to_dict(),\n",
    "}\n",
    "\n",
    "with open(output_metadata_path, 'w') as f:\n",
    "    json.dump(metadata, f, indent=2)\n",
    "\n",
    "logging.info(f\"Saved metadata to {output_metadata_path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save AnnData\n",
    "output_adata_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "adata.write_h5ad(output_adata_path)\n",
    "logging.info(f\"Saved AnnData to {output_adata_path}\")\n",
    "logging.info(\"Processing complete!\")"
   ]
  }
 ],
