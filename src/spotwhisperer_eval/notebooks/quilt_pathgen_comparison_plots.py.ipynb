   "metadata": {},
   "source": [
    "# Quilt1M vs PathGen Comparison Plots\n",
    "\n",
    "Create paired horizontal barplots comparing quilt1m and pathgen model performance across all benchmarks (lung, pathocell, musk)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ce231c92",
   "metadata": {
    "tags": [
     "parameters"
    ]
   },
   "outputs": [],
   "source": [
    "# Parameters from Snakemake\n",
    "datasets = snakemake.params.datasets\n",
    "benchmarks = snakemake.params.benchmarks"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "15cf52d6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import numpy as np\n",
    "import json\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "# Set style\n",
    "plt.style.use(snakemake.input.mpl_style)\n",
    "sns.set_palette(\"husl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8df92887",
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_benchmark_results():\n",
    "    \"\"\"Load all benchmark results for both datasets using Snakemake inputs.\"\"\"\n",
    "    results = defaultdict(dict)\n",
    "\n",
    "    # Load lung benchmark results\n",
    "    for i, lung_file in enumerate(snakemake.input.lung_results):\n",
    "        dataset = datasets[i]\n",
    "        try:\n",
    "            lung_df = pd.read_csv(lung_file)\n",
    "            # Extract key metrics from lung benchmark\n",
    "            region_mask = lung_df[\"metadata_col\"] == \"region_type_expert_annotation\"\n",
    "            celltype_mask = lung_df[\"metadata_col\"] == \"cell_type_annotations\"\n",
    "            \n",
    "            if region_mask.any():\n",
    "                results[dataset][\"lung_region_accuracy\"] = lung_df[region_mask][\"accuracy\"].iloc[0]\n",
    "                results[dataset][\"lung_region_f1\"] = lung_df[region_mask][\"f1\"].iloc[0]\n",
    "            \n",
    "            if celltype_mask.any():\n",
    "                results[dataset][\"lung_celltype_accuracy\"] = lung_df[celltype_mask][\"accuracy\"].iloc[0]\n",
    "                results[dataset][\"lung_celltype_f1\"] = lung_df[celltype_mask][\"f1\"].iloc[0]\n",
    "                \n",
    "        except (FileNotFoundError, IndexError, KeyError) as e:\n",
    "            print(f\"Warning: Could not load lung results for {dataset}: {e}\")\n",
    "\n",
    "    # Load MUSK benchmark results\n",
    "    for i, musk_file in enumerate(snakemake.input.musk_results):\n",
    "        dataset = datasets[i]\n",
    "        try:\n",
    "            with open(musk_file, \"r\") as f:\n",
    "                musk_data = json.load(f)\n",
    "            # Extract key metrics from MUSK benchmark\n",
    "            if \"skin\" in musk_data:\n",
    "                results[dataset][\"musk_skin_acc\"] = musk_data[\"skin\"].get(\"acc1\", None)\n",
    "            if \"pannuke\" in musk_data:\n",
    "                results[dataset][\"musk_pannuke_acc\"] = musk_data[\"pannuke\"].get(\"acc1\", None)\n",
    "        except (FileNotFoundError, json.JSONDecodeError, KeyError) as e:\n",
    "            print(f\"Warning: Could not load musk results for {dataset}: {e}\")\n",
    "\n",
    "    return dict(results)\n",
    "\n",
    "# Load all results\n",
    "all_results = load_benchmark_results()\n",
    "print(\"Loaded results for datasets:\", list(all_results.keys()))\n",
    "print(\"Available metrics:\", list(all_results.get(datasets[0], {}).keys()) if datasets else [])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c7297cb0",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_comparison_dataframe(results_dict):\n",
    "    \"\"\"Create a DataFrame suitable for paired barplot comparison.\"\"\"\n",
    "    data = []\n",
    "\n",
    "    # Define metric groups and their display names\n",
    "    metric_groups = {\n",
    "        \"Lung Benchmarks\": {\n",
    "            \"lung_region_accuracy\": \"Region Classification Accuracy\",\n",
    "            \"lung_celltype_accuracy\": \"Cell Type Classification Accuracy\",\n",
    "            \"lung_region_f1\": \"Region Classification F1\",\n",
    "            \"lung_celltype_f1\": \"Cell Type Classification F1\",\n",
    "        },\n",
    "        \"MUSK Benchmark\": {\n",
    "            \"musk_skin_acc\": \"Skin Cancer Classification\",\n",
    "            \"musk_pannuke_acc\": \"PanNuke Classification\",\n",
    "        },\n",
    "    }\n",
    "\n",
    "    for benchmark_group, metrics in metric_groups.items():\n",
    "        for metric_key, metric_name in metrics.items():\n",
    "            for dataset in datasets:\n",
    "                value = results_dict.get(dataset, {}).get(metric_key)\n",
    "                if value is not None:\n",
    "                    data.append({\n",
    "                        \"Dataset\": dataset.replace(\"_\", \" \").title(),\n",
    "                        \"Benchmark_Group\": benchmark_group,\n",
    "                        \"Metric\": metric_name,\n",
    "                        \"Value\": value,\n",
    "                        \"Metric_Full\": f\"{benchmark_group}: {metric_name}\",\n",
    "                    })\n",
    "\n",
    "    return pd.DataFrame(data)\n",
    "\n",
    "# Create comparison DataFrame\n",
    "comparison_df = create_comparison_dataframe(all_results)\n",
    "print(f\"Created comparison DataFrame with {len(comparison_df)} rows\")\n",
    "print(\"Available metrics for plotting:\")\n",
    "if len(comparison_df) > 0:\n",
    "    print(comparison_df.groupby(\"Benchmark_Group\")[\"Metric\"].unique())\n",
    "else:\n",
    "    print(\"No data found - will create empty plots\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "519f06aa",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_paired_barplots(df):\n",
    "    \"\"\"Create paired horizontal barplots comparing the two datasets across all metrics.\"\"\"\n",
    "\n",
    "    if len(df) == 0:\n",
    "        print(\"No data available for plotting\")\n",
    "        # Create empty plot\n",
    "        fig, ax = plt.subplots(figsize=(12, 8))\n",
    "        ax.text(0.5, 0.5, \"No benchmark data available\", \n",
    "                ha=\"center\", va=\"center\", transform=ax.transAxes)\n",
    "        ax.set_xlim(0, 1)\n",
    "        ax.set_ylim(0, 1)\n",
    "        plt.tight_layout()\n",
    "        return fig\n",
    "\n",
    "    # Get unique metrics and benchmark groups\n",
    "    benchmark_groups = df[\"Benchmark_Group\"].unique()\n",
    "\n",
    "    # Create figure with subplots for each benchmark group\n",
    "    n_groups = len(benchmark_groups)\n",
    "    fig, axes = plt.subplots(n_groups, 1, figsize=(14, 4 * n_groups), squeeze=False)\n",
    "    axes = axes.flatten()\n",
    "\n",
    "    # Colors for the two datasets\n",
    "    dataset_colors = {\"Quilt1M\": \"#e74c3c\", \"Pathgen\": \"#3498db\"}  # Red and blue\n",
    "\n",
    "    for i, benchmark_group in enumerate(benchmark_groups):\n",
    "        ax = axes[i]\n",
    "        group_data = df[df[\"Benchmark_Group\"] == benchmark_group]\n",
    "\n",
    "        if len(group_data) == 0:\n",
    "            ax.text(0.5, 0.5, f\"No data for {benchmark_group}\", \n",
    "                    ha=\"center\", va=\"center\", transform=ax.transAxes)\n",
    "            ax.set_title(benchmark_group, fontsize=14, fontweight=\"bold\")\n",
    "            continue\n",
    "\n",
    "        # Pivot to get datasets as columns\n",
    "        pivot_data = group_data.pivot(index=\"Metric\", columns=\"Dataset\", values=\"Value\")\n",
    "\n",
    "        if pivot_data.empty:\n",
    "            ax.text(0.5, 0.5, f\"No data for {benchmark_group}\", \n",
    "                    ha=\"center\", va=\"center\", transform=ax.transAxes)\n",
    "            ax.set_title(benchmark_group, fontsize=14, fontweight=\"bold\")\n",
    "            continue\n",
    "\n",
    "        # Create horizontal barplot\n",
    "        y_positions = np.arange(len(pivot_data.index))\n",
    "        bar_height = 0.35\n",
    "\n",
    "        # Plot bars for each dataset\n",
    "        for j, dataset in enumerate(datasets):\n",
    "            dataset_display = dataset.replace(\"_\", \" \").title()\n",
    "            if dataset_display in pivot_data.columns:\n",
    "                values = pivot_data[dataset_display]\n",
    "                color = dataset_colors.get(dataset_display, f\"C{j}\")\n",
    "                bars = ax.barh(\n",
    "                    y_positions + j * bar_height,\n",
    "                    values,\n",
    "                    bar_height,\n",
    "                    label=dataset_display,\n",
    "                    color=color,\n",
    "                    alpha=0.8,\n",
    "                )\n",
    "\n",
    "                # Add value labels on bars\n",
    "                for k, (bar, value) in enumerate(zip(bars, values)):\n",
    "                    if not pd.isna(value):\n",
    "                        ax.text(\n",
    "                            bar.get_width() + 0.01,\n",
    "                            bar.get_y() + bar.get_height() / 2,\n",
    "                            f\"{value:.3f}\",\n",
    "                            ha=\"left\",\n",
    "                            va=\"center\",\n",
    "                            fontsize=9,\n",
    "                        )\n",
    "\n",
    "        # Customize subplot\n",
    "        ax.set_yticks(y_positions + bar_height / 2)\n",
    "        ax.set_yticklabels(pivot_data.index)\n",
    "        ax.set_xlabel(\"Score\", fontsize=12)\n",
    "        ax.set_title(benchmark_group, fontsize=14, fontweight=\"bold\")\n",
    "        ax.legend(loc=\"lower right\")\n",
    "        ax.grid(True, alpha=0.3, axis=\"x\")\n",
    "\n",
    "        # Set x-axis limits to make bars more visible\n",
    "        if not pivot_data.empty and not pivot_data.isna().all().all():\n",
    "            max_val = pivot_data.max().max()\n",
    "            ax.set_xlim(0, max_val * 1.15)\n",
    "\n",
    "    plt.suptitle(\"Quilt1M vs PathGen: Benchmark Comparison\", fontsize=16, fontweight=\"bold\")\n",
    "    plt.tight_layout()\n",
    "    \n",
    "    return fig\n",
    "\n",
    "# Create the paired barplots\n",
    "fig = create_paired_barplots(comparison_df)\n",
    "\n",
    "# Save plots\n",
    "fig.savefig(snakemake.output.plots, dpi=300, bbox_inches=\"tight\")\n",
    "fig.savefig(snakemake.output.plots_svg, bbox_inches=\"tight\")\n",
    "plt.close(fig)\n",
    "\n",
    "print(f\"Saved paired barplots to {snakemake.output.plots} and {snakemake.output.plots_svg}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5a9986e5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_summary_table(results_dict):\n",
    "    \"\"\"Create and save a summary table with all metrics.\"\"\"\n",
    "\n",
    "    if not results_dict:\n",
    "        # Create empty summary\n",
    "        summary_df = pd.DataFrame({\n",
    "            \"Dataset\": datasets,\n",
    "            \"Note\": [\"No benchmark results available\"] * len(datasets),\n",
    "        })\n",
    "        return summary_df\n",
    "\n",
    "    # Convert results dict to DataFrame\n",
    "    summary_data = []\n",
    "\n",
    "    for dataset in datasets:\n",
    "        dataset_results = results_dict.get(dataset, {})\n",
    "        row = {\"Dataset\": dataset}\n",
    "\n",
    "        # Add all available metrics\n",
    "        for metric, value in dataset_results.items():\n",
    "            row[metric] = value\n",
    "\n",
    "        summary_data.append(row)\n",
    "\n",
    "    return pd.DataFrame(summary_data)\n",
    "\n",
    "# Create and save summary table\n",
    "summary_table = create_summary_table(all_results)\n",
    "summary_table.to_csv(snakemake.output.summary_table, index=False)\n",
    "\n",
    "print(f\"Saved summary table to {snakemake.output.summary_table}\")\n",
    "print(\"\\nSummary Statistics:\")\n",
    "print(summary_table.to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bbf94abe",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Print comparison analysis\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"QUILT1M vs PATHGEN COMPARISON ANALYSIS\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "if comparison_df.empty:\n",
    "    print(\"No benchmark data available for comparison.\")\n",
    "else:\n",
    "    # Calculate differences for each metric where both datasets have data\n",
    "    pivot_all = comparison_df.pivot(index=\"Metric_Full\", columns=\"Dataset\", values=\"Value\")\n",
    "\n",
    "    if len(pivot_all.columns) >= 2:\n",
    "        dataset1, dataset2 = pivot_all.columns[0], pivot_all.columns[1]\n",
    "\n",
    "        print(f\"\\nMETRIC COMPARISON ({dataset1} vs {dataset2}):\")\n",
    "        print(\"-\" * 50)\n",
    "\n",
    "        for metric in pivot_all.index:\n",
    "            val1 = pivot_all.loc[metric, dataset1]\n",
    "            val2 = pivot_all.loc[metric, dataset2]\n",
    "\n",
    "            if not pd.isna(val1) and not pd.isna(val2):\n",
    "                diff = val1 - val2\n",
    "                winner = dataset1 if diff > 0 else dataset2\n",
    "                print(f\"{metric}:\")\n",
    "                print(f\"  {dataset1}: {val1:.4f}\")\n",
    "                print(f\"  {dataset2}: {val2:.4f}\")\n",
    "                print(f\"  Difference: {diff:+.4f} (Winner: {winner})\")\n",
    "                print()\n",
    "            elif not pd.isna(val1):\n",
    "                print(f\"{metric}: Only {dataset1} has data ({val1:.4f})\")\n",
    "            elif not pd.isna(val2):\n",
    "                print(f\"{metric}: Only {dataset2} has data ({val2:.4f})\")\n",
    "            else:\n",
    "                print(f\"{metric}: No data available for either dataset\")\n",
    "\n",
    "print(\"\\nComparison analysis complete!\")"
   ]
  }
