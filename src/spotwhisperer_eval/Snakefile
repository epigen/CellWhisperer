rule spotwhisperer_test:
    """
    Performs both retrieval and CellWhisperer zero-shot evaluation for a trained SpotWhisperer model.

    Needs wandb unfortunately to write the logs
    """
    input:
        model=rules.train_spotwhisperer.output.model,
        base_config=ancient(PROJECT_DIR / "src/spotwhisperer_v3.yaml")
    output:
        # `config["paths"]["csv_logs"]` is set in `training.py`
        retrieval_and_cwevals=PROJECT_DIR / config["paths"]["csv_logs"] / "sweval___{dataset_combo}___{test_dataset}" / "metrics.csv",
        individual_clip_scores=PROJECT_DIR / config["paths"]["csv_logs"] / "sweval___{dataset_combo}___{test_dataset}" / "individual_clip_scores.csv",
    # log:
    #     "logs/retrieval_analysis_{dataset_combo}_{test_dataset}.log"
    params:
        test_dataset=lambda wildcards: wildcards.test_dataset.replace("__", ","),
        seed=SEEDS[0],
        batch_size=128,  # to avoid OOM of smaller GPUs
        project_dir=PROJECT_DIR,
    conda:
        "cellwhisperer"
    resources:
        mem_mb=100000,
        runtime=16*60,
        slurm=slurm_gres("small", num_cpus=2),  # for some reason, multi-processing freezes the process in the end (or does it?) -.-
    shell: """
        cd {params.project_dir}
        cellwhisperer test \
            --config {input.base_config} \
            --model_ckpt {input.model} \
            --data.dataset_names {params.test_dataset} \
            --data.train_fraction 0.0 \
            --batch_size {params.batch_size} \
            --seed_everything {params.seed} \
            --nproc 0 \
            --wandb '' \
            --trainer.logger.init_args.version sweval___{wildcards.dataset_combo}___{wildcards.test_dataset}
    """

rule aggregate_spotwhisperer_test:
    """
    Aggregate retrieval and CW eval analysis results across all test datasets for each model
    """
    input:
        retrieval_results=lambda wildcards: expand(
            rules.spotwhisperer_test.output.retrieval_and_cwevals,
            dataset_combo=wildcards.dataset_combo,
            test_dataset=BASE_DATASETS,
        )
    output:
        aggregated_retrieval=BENCHMARKS_DIR / "retrieval" / "{dataset_combo}" / "aggregated_retrieval.csv",
        aggregated_cwevals=BENCHMARKS_DIR / "retrieval" / "{dataset_combo}" / "aggregated_cwevals.csv"
    conda:
        "cellwhisperer"
    params:
        dataset_combo=lambda wildcards: wildcards.dataset_combo.replace("__", ","),
        test_datasets=BASE_DATASETS
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=1"
    script:
        "scripts/aggregate_retrieval_results.py"  # TODO rename


rule create_analysis_plots:
    """
    Create horizontal barplots for each test dataset showing performance
    across five model types for all metrics

    """
    input:
        # HEST benchmark results
        hest_results=lambda wildcards: expand(
            rules.aggregate_hest_evaluation.output.aggregated_hest,
            dataset_combo=[MODEL_MAPPINGS[wildcards.test_dataset][model_type] for model_type in ["naive_baseline", "bimodal_matching", "bimodal_bridge", "trimodal"]],
            test_dataset=wildcards.test_dataset
        ),
        # MUSK benchmark results
        musk_results=lambda wildcards: expand(
            rules.aggregate_musk_results.output.aggregated_musk,
            dataset_combo=[MODEL_MAPPINGS[wildcards.test_dataset][model_type] for model_type in ["naive_baseline", "bimodal_matching", "bimodal_bridge", "trimodal"]],
            test_dataset=wildcards.test_dataset
        ),
        # Lung benchmark results (20x and thus not supported)
        # lung_results=lambda wildcards: expand(
        #     rules.aggregate_lung_evaluation.output.aggregated_lung,
        #     dataset_combo=[MODEL_MAPPINGS[wildcards.test_dataset][model_type] for model_type in ["naive_baseline", "bimodal_matching", "bimodal_bridge", "trimodal"]],
        #     test_dataset=wildcards.test_dataset
        # ),
        # Retrieval results
        retrieval_results=lambda wildcards: expand(
            rules.aggregate_spotwhisperer_test.output.aggregated_retrieval,
            dataset_combo=[MODEL_MAPPINGS[wildcards.test_dataset][model_type] for model_type in ["naive_baseline", "bimodal_matching", "bimodal_bridge", "trimodal"]],
            test_dataset=wildcards.test_dataset
        ),
        # cellwhisperer results
        cwevals_results=lambda wildcards: expand(
            rules.aggregate_spotwhisperer_test.output.aggregated_cwevals,
            dataset_combo=[MODEL_MAPPINGS[wildcards.test_dataset][model_type] for model_type in ["naive_baseline", "bimodal_matching", "bimodal_bridge", "trimodal"]],
            test_dataset=wildcards.test_dataset
        )
    output:
        plots=report(BENCHMARKS_DIR / "analysis_plots" / "{test_dataset}" / "performance_comparison.png", category="aggregated", subcategory=lambda wildcards: DATASET_PAIR_MAPPING[wildcards.test_dataset], labels={"Analysis": "Overview", "Format": "plot"}),
    params:
        model_mappings=lambda wildcards: MODEL_MAPPINGS[wildcards.test_dataset],
        benchmarks_dir=BENCHMARKS_DIR,
        dataset_combos=DATASET_COMBOS,
        metrics = [
            "hest",     # hest
            "pannuke",  # musk
            "skin",

            # "lung_tissue_region_type_expert_annotation_accuracy",  # lung is 20x and thus not supported
            # "lung_tissue_region_type_expert_annotation_f1_weighted",
            # "lung_tissue_region_type_expert_annotation_f1_macro",
            # "lung_tissue_cell_type_annotations_accuracy",
            # "lung_tissue_cell_type_annotations_f1_weighted",
            # "lung_tissue_cell_type_annotations_f1_macro",

            "valfn_zshot_TabSap_cell_lvl/f1_macroAvg",
            # "valfn_zshot_TabSap_celltype_lvl/f1_macroAvg",
            "valfn_zshot_TabSap_cell_lvl/rocauc_macroAvg",
            # "valfn_zshot_TabSap_celltype_lvl/rocauc_macroAvg"
            # TODO later "valfn_human_disease_strictly_deduplicated_dmis-lab_biobert-v1.1_CLS_pooling/text_as_classes_recall_at_5_macroAvg" (check whether it is being generated)

        ],
    conda:
        "cellwhisperer"
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=4"
    notebook:
        "notebooks/create_analysis_plots.py.ipynb"

