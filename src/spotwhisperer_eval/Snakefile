"""
SpotWhisperer Experiment Pipeline (modularized)

Trains models across dataset combinations and evaluates them via HEST, MUSK,
CellWhisperer, and retrieval analyses. Plotting and per-class analyses are included.
"""

# Include shared configuration and modular rule files
include: "../shared/config.smk"
include: "../shared/rules/dataset_processing.smk"
include: "rules/common.smk"
include: "rules/training.smk"
include: "rules/retrieval_eval.smk"
include: "rules/plots.smk"
include: "rules/metadata_and_analysis.smk"
include: "rules/hest_benchmark.smk"
include: "rules/lung_benchmark.smk"
include: "rules/musk_benchmark.smk"
include: "rules/cellwhisperer_benchmark.smk"
include: "rules/model_interpretation.smk"


rule aggregate_hest_evaluation:
    """
    Copy aggregated HEST summaries into the benchmarks directory for dataset_combo.
    """
    input:
        lambda wildcards: expand(
            rules.aggregate_hest_results.output.aggregated_summary,
            model="spotwhisperer_{}".format(wildcards.dataset_combo),
            allow_missing=True,
        )
    output:
        aggregated_hest=BENCHMARKS_DIR / "hest" / "{dataset_combo}" / "aggregated_results.json"
    conda:
        "cellwhisperer"
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=1"
    shell: """
        cp {input} {output.aggregated_hest}
    """


rule aggregate_musk_results:
    """
    Copy aggregated MUSK summaries into the benchmarks directory for dataset_combo.
    """
    input:
        performance_summary=lambda wildcards: expand(
            rules.musk_performance_summary.output.summary,
            model="spotwhisperer_{}".format(wildcards.dataset_combo),
            seed=SEEDS[0],
            allow_missing=True,
        )
    output:
        aggregated_musk=BENCHMARKS_DIR / "musk" / "{dataset_combo}" / "performance_summary.json"
    conda:
        "cellwhisperer"
    resources:
        mem_mb=50000,
        slurm="cpus-per-task=1"
    shell: """
        cp {input.performance_summary} {output.aggregated_musk}
    """


rule all:
    """
    Default target: run training, evaluations, plots, and analyses end-to-end.
    """
    input:
        # All trained models
        expand(
            rules.train_spotwhisperer.output.model,
            dataset_combo=DATASET_COMBOS,
        ),

        # Analysis plots
        expand(rules.create_analysis_plots.output.plots, test_dataset=BASE_DATASETS),
        expand(rules.create_retrieval_plots.output.plots, test_dataset=BASE_DATASETS),
        rules.spider_performance_plot.output.plot,
        rules.bimodal_bridge_plot.output.plot,

        # Per-class comparison for MUSK
        expand(
            rules.musk_per_class_analysis.output.analysis,
            seed=SEEDS[0],
        ),

        # Per-class comparison for CellWhisperer benchmark
        expand(
            rules.cellwhisperer_per_class_analysis.output.analysis,
            allow_missing=True,
        ),

        # Sample metadata extraction
        expand(
            rules.extract_sample_metadata.output.metadata,
            dataset=[dataset for base_dataset in BASE_DATASETS for dataset in base_dataset.split("__")],
            allow_missing=True,
        ),

        # Per-class comparison for retrieval analysis
        expand(
            rules.retrieval_per_class_analysis.output.analysis,
            dataset=BASE_DATASETS,
            allow_missing=True,
        ),

        # Per-class comparison for HEST benchmark
        expand(
            rules.hest_per_class_analysis.output.analysis,
            allow_missing=True,
        ),

        # Model interpretation analyses
        rules.model_interpretation_all.input,

    default_target: True
