from pathlib import Path
import itertools
SEEDS = [0, 1, 2, 3, 4]  # note that most of seeds 0 and 1 were generated with a slightly previous version of the code, with `integration_TabSap` missing

# TODO temporarily deleting some of the slower runs
CONFIGS = [p.stem for p in Path("delta_config").glob("*.yaml") if p.stem not in ["locking_mode_UU", "locking_mode_UL", "scgpt"]]
# CONFIGS = ["full_model"]

rule all:
    input:
        [f"results/{config}/seed_{seed}.ckpt" for seed in SEEDS for config in CONFIGS]

rule train:
    input:
        delta_config="delta_config/{config}.yaml",
        base_config=ancient("base_config.yaml")
    output:
        "results/{config}/seed_{seed}.ckpt"
    conda:
        "cellwhisperer_fixed"  # NOTE: not subject to automatic updates
    resources:
        mem_mb=lambda wildcards: 1000000 if wildcards.config == "scgpt" else 120000,
        slurm=slurm_gres("large", num_cpus=20)
    shell: """
        cellwhisperer fit --config {input.base_config} --config {input.delta_config} --seed_everything {wildcards.seed} --last_model_path {output} --wandb {wildcards.config}_{wildcards.seed}
    """

