from os import popen
from pathlib import Path

PROJECT_DIR = Path(popen("git rev-parse --show-toplevel").read().strip())
REPLICATES = ["0"]  # just to please annotation_processing.smk
DATASETS = ["baseline", "with_study_info", "with_study_info_metasra"]

configfile: PROJECT_DIR / "config.yaml"

include: "../../pre_training_processing/rules/annotation_processing.smk"  # process_annotation_local

rule all:
    input: "results/scores.csv"


rule generate_dataset:
    """
    Generate different dataset "configurations" based on the `name` wildcard. Prepare these sets as requests for the annotation processing

    1. baseline: Current implementation (with metasra, without additional information)
    2. with_study_info: With additional study-level information and metasra
    3. with_study_info_metsra: With additional sample-level information

    # TODO add study_title (it's not in the csv at the moment)
    NOTE: as we work with JSON downstream, the order of the rows changes

    Baseline fields: geo_title geo_source_name sample_type mapped_ontology_terms raw_biosample_metadata treatment

    MetaSRA fields: sample_type mapped_ontology_terms

    Study fields: treatment_protocol series_summary series_design growth_protocol
    """
    input:
        "resources/archs4_metadata_table.geoextended.tsv"
    output:
        csv="results/annotation_testing_{dataset}.csv",
        yaml=PROJECT_DIR / "results" / "pre_training_processing" / "requests" / "{dataset,[^/]+}" / "0" / "1-of-1.yaml"  # note: this overlaps with the path generated by process_annotation_local. And it perturbs the order
    run:
        import pandas as pd
        import yaml

        df = pd.read_csv(input[0], sep="\t", index_col=0)

        if wildcards.dataset == "baseline":
            df = df[["geo_title", "geo_source_name", "sample_type", "mapped_ontology_terms", "raw_biosample_metadata", "treatment"]]
        elif wildcards.dataset == "with_study_info":
            df = df[["geo_title", "geo_source_name","raw_biosample_metadata", "treatment", "treatment_protocol", "series_summary", "series_design", "growth_protocol"]]
        elif wildcards.dataset == "with_study_info_metasra":
            df = df[["geo_title", "geo_source_name", "sample_type", "mapped_ontology_terms", "raw_biosample_metadata", "treatment", "treatment_protocol", "series_summary", "series_design", "growth_protocol"]]

        # write the yaml file with keys as index and values of each row's entries as key-value pairs
        annotations = df.to_dict(orient="index")
        with open(output.yaml, "w") as f:
            yaml.dump(annotations, f)

        df.to_csv(output.csv, index=True)


rule evaluate_datasets:
    """
    Evaluate the performance of the annotation model on different datasets in a relative manner.
    The request to show is the one with the most information (with_study_info_metasra). This makes sense,
    because we do have this information and if we don't use it, it's a waste (and should not be rewarded in the evaluation).
    """
    input:
        llm_responses=expand(rules.process_annotation_local.output.processed_annotation, replicate=["0"], scatteritem=["1-of-1"], dataset=DATASETS),
        llm_requests=rules.process_annotation_local.output.requests.format(replicate="0", scatteritem="1-of-1", dataset="with_study_info_metasra"),
        prompt="prompts/evaluation_prompt.txt"
    output:
        scores="results/scores.csv"
    params:
        datasets=DATASETS
    conda: "cellwhisperer"
    notebook:
        "notebooks/evaluate_dataset.py.ipynb"
